{
  "name": "elaris",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Elaris — a top-down creature-taming survival-builder PWA (Phase 1).",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "deploy": "npm run build && firebase deploy --only hosting"
  },
  "dependencies": {
    "idb": "8.0.3",
    "phaser": "3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@vitest/browser": "4.1.10",
    "fake-indexeddb": "6.2.5",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "7.3.6",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10"
  }
}
